{
  "name": "alan-frontdesk-ai-backend",
  "version": "1.0.0",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun --hot index.ts",
    "start": "bun index.ts",
    "test": "bun test",
    "db:generate": "bunx prisma generate",
    "db:migrate": "bunx prisma migrate dev",
    "db:migrate:deploy": "bunx prisma migrate deploy",
    "db:push": "bunx prisma db push",
    "db:seed": "bunx prisma db seed",
    "db:studio": "bunx prisma studio",
    "db:reset": "bunx prisma migrate reset",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "setup": "docker compose up -d && sleep 3 && bunx prisma migrate dev && bunx prisma db seed"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "dotenv": "^17.2.3",
    "prisma": "^6"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@prisma/client": "^6"
  }
}
