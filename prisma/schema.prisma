generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

enum QuestionType {
  single_select
  multi_select
  text
  schedule
}

model QuestionTemplate {
  id        String       @id @default(cuid())
  nicheType String
  questionId String
  question  String
  type      QuestionType
  options   Json?        // [{label, value, description?}]
  required  Boolean      @default(true)
  order     Int
  dependsOn Json?        // {questionId: string, values: string[]} or null
  category  String       @default("niche") // "niche" or "common"
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt

  @@unique([nicheType, questionId])
  @@index([nicheType])
}

model OnboardingSession {
  id                  String   @id @default(cuid())
  nicheType           String
  businessName        String?
  businessDescription String?
  currentQuestionIndex Int     @default(0)
  completed           Boolean  @default(false)
  agentId             String?
  metadata            Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  answers OnboardingAnswer[]
}

model OnboardingAnswer {
  id         String   @id @default(cuid())
  sessionId  String
  questionId String
  answer     Json
  skipped    Boolean  @default(false)
  answeredAt DateTime @default(now())

  session OnboardingSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, questionId])
  @@index([sessionId])
}

// ===== AI Agent Pipeline Models =====

model Agent {
  id                  String   @id @default(cuid())
  businessName        String
  businessDescription String?
  niche               String
  tone                String   @default("friendly")
  systemPrompt        String   @db.Text
  config              Json     // Full onboarding state snapshot
  escalationStrategy  String   @default("collect_and_notify")
  handoffContact      String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  knowledgeChunks KnowledgeChunk[]
  conversations   Conversation[]
  actionQueues    ActionQueue[]
  bookings        Booking[]
  leads           Lead[]
  escalations     Escalation[]
}

model KnowledgeChunk {
  id        String                      @id @default(cuid())
  agentId   String
  category  String                      // services, insurance, hours, emergency, booking, general
  content   String   @db.Text
  embedding Unsupported("vector(3072)") // xAI v3 embedding dimension
  metadata  Json?
  createdAt DateTime @default(now())

  agent Agent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId])
  @@index([agentId, category])           // Fast lookup by agent + category
}

model Conversation {
  id           String   @id @default(cuid())
  agentId      String
  customerName String?
  status       String   @default("active") // active, closed, escalated
  metadata     Json?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  agent        Agent          @relation(fields: [agentId], references: [id], onDelete: Cascade)
  messages     Message[]
  actionQueues ActionQueue[]
  bookings     Booking[]
  leads        Lead[]
  escalations  Escalation[]

  @@index([agentId])
  @@index([agentId, status])              // Fast lookup active conversations per agent
}

model Message {
  id             String   @id @default(cuid())
  conversationId String
  role           String   // user, assistant
  content        String   @db.Text
  sources        Json?    // categories used for RAG context
  action         Json?    // {type: "booking", data: {...}} if action detected
  createdAt      DateTime @default(now())

  conversation  Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionQueues  ActionQueue[]

  @@index([conversationId])
  @@index([conversationId, createdAt])    // Fast message history in order
}

// ===== Action Queue System =====

model ActionQueue {
  id             String    @id @default(cuid())
  agentId        String
  conversationId String
  messageId      String
  actionType     String    // 'booking', 'escalate', 'lead', etc.
  payload        Json      // Action data from LLM
  status         String    @default("pending") // pending, processing, completed, failed
  priority       Int       @default(0) // Higher = more urgent
  attempts       Int       @default(0)
  maxAttempts    Int       @default(3)
  error          String?
  processedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  booking      Booking?
  lead         Lead?
  escalation   Escalation?

  @@index([agentId, status])
  @@index([status, priority, createdAt])
}

model Booking {
  id              String    @id @default(cuid())
  agentId         String
  conversationId  String
  actionQueueId   String    @unique
  customerName    String?
  customerEmail   String?
  customerPhone   String?
  service         String
  requestedDate   DateTime?
  requestedDateRaw String?
  status          String    @default("requested") // requested, confirmed, cancelled, completed
  notes           String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionQueue  ActionQueue  @relation(fields: [actionQueueId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
  @@index([agentId, requestedDate])
}

model Lead {
  id             String   @id @default(cuid())
  agentId        String
  conversationId String
  actionQueueId  String   @unique
  name           String?
  email          String?
  phone          String?
  source         String   @default("chat")
  interest       String?
  status         String   @default("new") // new, contacted, qualified, converted
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionQueue  ActionQueue  @relation(fields: [actionQueueId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
}

model Escalation {
  id             String    @id @default(cuid())
  agentId        String
  conversationId String
  actionQueueId  String    @unique
  reason         String
  customerInfo   Json?
  status         String    @default("pending") // pending, assigned, resolved
  assignedTo     String?
  resolvedAt     DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  agent        Agent        @relation(fields: [agentId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  actionQueue  ActionQueue  @relation(fields: [actionQueueId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
}
